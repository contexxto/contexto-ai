# Copia este archivo como .env y completa los valores reales
# NUNCA subas el .env real al repositorio (está en .gitignore)

# ── Base de datos (dev local con Docker/PostGIS) ──
POSTGRES_DB=contexto_v2
POSTGRES_USER=contexto_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# En producción (Render + Supabase): URL completa del Session Pooler.
# Tiene precedencia sobre los POSTGRES_* de arriba.
# Formato: postgresql+asyncpg://postgres.PROJECT:PASSWORD@aws-...pooler.supabase.com:5432/postgres
DATABASE_URL_OVERRIDE=

# ── LLM — Anthropic Claude ──
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-sonnet-4-5-20250929

# ── SSL ──
# false SOLO en redes corporativas con SSL inspection (dev local).
# En producción debe ser SIEMPRE "true".
SSL_VERIFY=true

# ── Seguridad (Fase 3) ──
# Orígenes permitidos para CORS, separados por comas.
# En producción: el dominio de Vercel. En dev: localhost.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Clave que el frontend envía en el header X-API-Key.
# Vacía en dev (el check se desactiva). En producción: clave fuerte.
API_KEY=
